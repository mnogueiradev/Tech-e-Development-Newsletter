# Banco de dados TiDB
TIDB_URL=mysql://usuario:senha@gateway.tidbcloud.com:4000/test

# API Resend (envio de emails)
RESEND_API_KEY=re_sua_chave_aqui

# API Brave News
BRAVE_API_KEY=sua_chave_brave_aqui

# Porta do servidor
PORT=3000

# =======================
# PAINEL DE ADMINISTRAÇÃO
# =======================
ADMIN_EMAIL=seu@email.com
ADMIN_PASSWORD=uma_senha_muito_segura

# Token para /trigger-email e rotas admin sensíveis (use o mesmo no cron externo)
ADMIN_TOKEN=um_token_alfanumerico_aleatorio_seguro

# JWT do painel admin (opcional — fallback: ADMIN_TOKEN)
JWT_SECRET=

# =======================
# FRONTEND (build)
# =======================
# Deixe vazio se frontend e backend rodam no mesmo domínio (Oracle Cloud).
# Só defina se API estiver em host diferente do site.
# NEXT_PUBLIC_API_URL=https://techndevn.com

# =======================
# CRON EXTERNO (deploy/trigger-newsletter.sh)
# =======================
# NEWSLETTER_URL=https://techndevn.com
